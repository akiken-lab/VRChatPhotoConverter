<Window x:Class="PhotoConverterApp.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="設定"
        Height="680"
        Width="980"
        MinHeight="640"
        MinWidth="920"
        WindowStartupLocation="CenterOwner"
        Closing="SettingsWindow_Closing">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">
            <TabItem Header="基本">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8">
                        <Border Style="{StaticResource PanelBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="90"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,10,8,0" Text="ルール名" VerticalAlignment="Center"/>
                                <TextBox x:Name="RuleNameTextBox" Grid.Row="0" Grid.Column="1" Margin="0,6,8,0" TextChanged="TextInputChanged"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,10,8,0" Text="入力フォルダ" VerticalAlignment="Center"/>
                                <TextBox x:Name="SourceDirTextBox" Grid.Row="1" Grid.Column="1" Margin="0,6,8,0" TextChanged="TextInputChanged"/>
                                <Button Grid.Row="1" Grid.Column="2" Content="参照" Style="{StaticResource SecondaryButtonStyle}" Margin="0,6,0,0" Click="BrowseSourceDir_Click"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,10,8,0" Text="JPEG出力先" VerticalAlignment="Center"/>
                                <TextBox x:Name="JpegOutputDirTextBox" Grid.Row="2" Grid.Column="1" Margin="0,6,8,0" TextChanged="TextInputChanged"/>
                                <Button Grid.Row="2" Grid.Column="2" Content="参照" Style="{StaticResource SecondaryButtonStyle}" Margin="0,6,0,0" Click="BrowseJpegOutputDir_Click"/>

                                <TextBlock x:Name="PngArchiveLabelTextBlock" Grid.Row="3" Grid.Column="0" Margin="0,10,8,0" Text="PNG保管先" VerticalAlignment="Center"/>
                                <TextBox x:Name="PngArchiveDirTextBox" Grid.Row="3" Grid.Column="1" Margin="0,6,8,0" TextChanged="TextInputChanged"/>
                                <Button x:Name="BrowsePngArchiveDirButton" Grid.Row="3" Grid.Column="2" Content="参照" Style="{StaticResource SecondaryButtonStyle}" Margin="0,6,0,0" Click="BrowsePngArchiveDir_Click"/>

                                <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="0,12,0,0">
                                    <CheckBox x:Name="IncludeSubdirectoriesCheckBox" Content="サブフォルダを含める" Margin="0,0,20,0" Checked="ToggleInputChanged" Unchecked="ToggleInputChanged"/>
                                    <CheckBox x:Name="MonitorOnStartupCheckBox" Content="起動時に監視を開始" Margin="0,0,20,0" Checked="ToggleInputChanged" Unchecked="ToggleInputChanged"/>
                                    <CheckBox x:Name="CreateMissingFoldersCheckBox" Content="保存時に出力先を作成" IsChecked="True" Checked="ToggleInputChanged" Unchecked="ToggleInputChanged"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource PanelBorderStyle}" Margin="0,8,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="70"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="JPEG品質" VerticalAlignment="Center"/>
                                <Slider x:Name="JpegQualitySlider" Grid.Column="1" Minimum="1" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="JpegQualitySlider_ValueChanged"/>
                                <TextBlock x:Name="JpegQualityValueTextBlock" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource PanelBorderStyle}" Margin="0,8,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,10,8,0" Text="PNG扱い" VerticalAlignment="Center"/>
                                <ComboBox x:Name="PngModeComboBox" Grid.Row="0" Grid.Column="1" Margin="0,6,0,0" SelectionChanged="SelectionInputChanged">
                                    <ComboBoxItem Content="移動（Move）"/>
                                    <ComboBoxItem Content="コピー（Copy）"/>
                                    <ComboBoxItem Content="削除（Delete）"/>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <TextBlock x:Name="ValidationMessageTextBlock" Margin="4,10,4,0" Foreground="#B42318" TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="高度">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8">
                        <Border Style="{StaticResource PanelBorderStyle}" Margin="0,8,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,10,8,0" Text="重複時" VerticalAlignment="Center"/>
                                <ComboBox x:Name="DuplicatePolicyComboBox" Grid.Row="0" Grid.Column="1" Margin="0,6,0,0" SelectionChanged="SelectionInputChanged">
                                    <ComboBoxItem Content="連番リネーム（Rename）"/>
                                    <ComboBoxItem Content="上書き（Overwrite）"/>
                                    <ComboBoxItem Content="スキップ（Skip）"/>
                                </ComboBox>

                                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,10,8,0" Text="除外秒数（0-600）" VerticalAlignment="Center"/>
                                <TextBox x:Name="RecentGuardTextBox" Grid.Row="1" Grid.Column="1" Margin="0,6,0,0" TextChanged="TextInputChanged"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,10,8,0" Text="ログレベル" VerticalAlignment="Center"/>
                                <ComboBox x:Name="LogLevelComboBox" Grid.Row="2" Grid.Column="1" Margin="0,6,0,0" SelectionChanged="SelectionInputChanged">
                                    <ComboBoxItem Content="エラー"/>
                                    <ComboBoxItem Content="警告"/>
                                    <ComboBoxItem Content="情報"/>
                                    <ComboBoxItem Content="デバッグ"/>
                                </ComboBox>

                                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,10,8,0" Text="監視対象EXE" VerticalAlignment="Center"/>
                                <TextBox x:Name="WatchExeNameTextBox" Grid.Row="3" Grid.Column="1" Margin="0,6,0,0" TextChanged="TextInputChanged"/>

                                <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="0,12,0,0">
                                    <CheckBox x:Name="DryRunCheckBox" Content="ドライラン" Margin="0,0,20,0" Checked="ToggleInputChanged" Unchecked="ToggleInputChanged"/>
                                    <CheckBox x:Name="LaunchOnWindowsStartupCheckBox" Content="Windows起動時にアプリ起動" IsChecked="True" Checked="ToggleInputChanged" Unchecked="ToggleInputChanged"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Expander Header="危険操作" Margin="0,8,0,0">
                            <StackPanel Margin="8">
                                <TextBlock Text="履歴DBのリセットは重複判定履歴を消去します。" Foreground="#5B6474"/>
                                <Button Content="履歴DBをリセット" Style="{StaticResource DestructiveButtonStyle}" Margin="0,8,0,0" Click="ResetHistoryDb_Click"/>
                                <Button Content="設定フォルダを開く" Style="{StaticResource SecondaryButtonStyle}" Margin="0,8,0,0" Click="OpenSettingsFolder_Click"/>
                                <Button Content="ログフォルダを開く" Style="{StaticResource SecondaryButtonStyle}" Margin="0,8,0,0" Click="OpenLogFolder_Click"/>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Border Grid.Row="1" Background="#EEF2FF" BorderBrush="#C7D7FE" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="DirtyStateTextBlock" VerticalAlignment="Center" Foreground="#1D4ED8" Text="変更はありません"/>
                <Button x:Name="SaveButton" Grid.Column="1" Content="保存" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" Click="Save_Click" IsEnabled="False"/>
                <Button x:Name="CancelButton" Grid.Column="2" Content="キャンセル" Style="{StaticResource SecondaryButtonStyle}" Click="Cancel_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>

