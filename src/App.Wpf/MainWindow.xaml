<Window x:Class="PhotoConverterApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VRC JPEG Auto Generator"
        Height="760"
        Width="1120"
        MinHeight="680"
        MinWidth="980"
        Background="#F5F7FB">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="ステータス" FontSize="28" FontWeight="SemiBold"/>
                <TextBlock Text="常駐運用の状態確認と即時操作" Foreground="#5B6474" Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                <Button x:Name="OpenSettingsButton" Content="設定..." Style="{StaticResource SecondaryButtonStyle}" Click="OpenSettings_Click"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*"/>
                <ColumnDefinition Width="1.8*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}" Margin="0,0,12,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="監視状態" FontSize="18" FontWeight="SemiBold"/>
                            <Border x:Name="StatusBadge" Margin="10,0,0,0" Padding="10,4" CornerRadius="10" Background="#FEE2E2">
                                <TextBlock x:Name="StatusBadgeTextBlock" Text="停止中" FontWeight="SemiBold" Foreground="#B42318"/>
                            </Border>
                        </StackPanel>
                        <TextBlock x:Name="StatusSummaryTextBlock" Text="監視は停止しています。" Foreground="#5B6474" Margin="0,8,0,0"/>

                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                            <ToggleButton x:Name="MonitorToggleButton"
                                          Style="{StaticResource ToggleSwitchButtonStyle}"
                                          Content="監視を開始"
                                          Checked="MonitorToggleButton_Checked"
                                          Unchecked="MonitorToggleButton_Unchecked"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Width="290" Margin="20,0,0,0">
                        <TextBlock Text="実行対象" FontWeight="SemiBold" Foreground="#5B6474"/>
                        <DockPanel Margin="0,4,0,8">
                            <Button x:Name="CopyTargetExeButton" Content="📋" Width="26" Height="22" Margin="6,0,0,0" Click="CopyTargetExe_Click" DockPanel.Dock="Right"/>
                            <TextBlock x:Name="TargetExeTextBlock" Text="未設定" TextTrimming="CharacterEllipsis" ToolTip="未設定"/>
                        </DockPanel>
                        <TextBlock Text="使用ルール" FontWeight="SemiBold" Foreground="#5B6474"/>
                        <TextBlock x:Name="ActiveRuleTextBlock" Text="未設定" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource PanelBorderStyle}">
                <StackPanel>
                    <TextBlock Text="直近サマリ" FontSize="18" FontWeight="SemiBold"/>
                    <UniformGrid Columns="4" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="最終実行" Foreground="#5B6474"/>
                            <TextBlock x:Name="LastRunTextBlock" Text="未実行" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="スキャン" Foreground="#5B6474"/>
                            <TextBlock x:Name="ScannedCountTextBlock" Text="0" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="成功" Foreground="#5B6474"/>
                            <TextBlock x:Name="ConvertedCountTextBlock" Text="0" FontWeight="SemiBold" Foreground="#0E7A43"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="エラー" Foreground="#5B6474"/>
                            <TextBlock x:Name="ErrorCountTextBlock" Text="0" FontWeight="SemiBold" Foreground="#B42318"/>
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="LastErrorBorder" Grid.Column="0" Style="{StaticResource PanelBorderStyle}" Margin="0,0,12,0" BorderBrush="#FECACA" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="最後のエラー" FontSize="18" FontWeight="SemiBold" Foreground="#B42318"/>
                    <TextBlock x:Name="LastErrorTextBlock" Margin="0,10,0,10" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="ログ" Style="{StaticResource SecondaryButtonStyle}" Click="OpenLogs_Click" Margin="0,0,8,0"/>
                        <Button Content="エラーをコピー" Style="{StaticResource SecondaryButtonStyle}" Click="CopyLastError_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource PanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="最新ログ" FontSize="18" FontWeight="SemiBold"/>
                    <TextBox x:Name="LogTailTextBox" Grid.Row="1" Margin="0,10,0,10" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Background="#FBFCFE"/>
                    <Border x:Name="LogEmptyStateBorder" Grid.Row="1" Margin="0,10,0,10" Background="#FBFCFE" BorderBrush="#D0D5DD" BorderThickness="1" CornerRadius="8" Padding="12" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="まだ実行ログがありません。" FontWeight="SemiBold"/>
                            <TextBlock Text="下の「今すぐ変換」または監視をオンにして開始してください。" Margin="0,6,0,0" Foreground="#5B6474" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                        <Button Content="ログ" Style="{StaticResource SecondaryButtonStyle}" Click="OpenLogs_Click" Margin="0,0,8,0"/>
                        <Button Content="JPEG出力先" Style="{StaticResource SecondaryButtonStyle}" Click="OpenOutput_Click" Margin="0,0,8,0"/>
                        <Button x:Name="RunNowButton" Content="今すぐ変換" Style="{StaticResource PrimaryButtonStyle}" Click="RunNow_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="3" Margin="2,12,0,0">
            <TextBlock x:Name="ProgressTextBlock" Foreground="#344054" Text="待機中"/>
            <ProgressBar x:Name="ConversionProgressBar" Height="10" Margin="0,8,0,0" Minimum="0" Maximum="1" Value="0"/>
            <TextBlock x:Name="ProgressDetailTextBlock" Margin="0,8,0,0" Foreground="#5B6474" Text=""/>
        </StackPanel>
    </Grid>
</Window>
