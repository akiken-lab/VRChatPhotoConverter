<Window x:Class="PhotoConverterApp.FirstRunWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="初回セットアップ"
        Height="540"
        Width="780"
        MinHeight="500"
        MinWidth="720"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock x:Name="StepHeaderTextBlock" Text="ステップ1/3 ゲームを選択" FontSize="24" FontWeight="SemiBold"/>
            <TextBlock x:Name="StepDescriptionTextBlock" Text="まずはゲームプリセットを選んでください。" Foreground="#5B6474" Margin="0,6,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource PanelBorderStyle}">
            <Grid>
                <Grid x:Name="Step1Panel">
                    <StackPanel Width="420" HorizontalAlignment="Left" VerticalAlignment="Top">
                        <TextBlock Text="ゲームプリセット" Margin="0,0,0,8"/>
                        <ComboBox x:Name="PresetComboBox" SelectedIndex="0">
                            <ComboBoxItem Content="VRChat"/>
                        </ComboBox>
                        <TextBlock Text="将来、ここに他ゲームを追加できます。" Foreground="#5B6474" Margin="0,10,0,0"/>
                    </StackPanel>
                </Grid>

                <Grid x:Name="Step2Panel" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="90"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Margin="0,8,8,0" Text="入力フォルダ" VerticalAlignment="Center"/>
                    <TextBox x:Name="SourceDirTextBox" Grid.Column="1" Margin="0,4,8,0"/>
                    <Button Grid.Column="2" Content="参照" Style="{StaticResource SecondaryButtonStyle}" Margin="0,4,0,0" Click="BrowseSourceDir_Click"/>
                </Grid>

                <Grid x:Name="Step3Panel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="90"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,8,8,0" Text="JPEG出力先" VerticalAlignment="Center"/>
                    <TextBox x:Name="JpegDirTextBox" Grid.Row="0" Grid.Column="1" Margin="0,4,8,0"/>
                    <Button Grid.Row="0" Grid.Column="2" Content="参照" Style="{StaticResource SecondaryButtonStyle}" Margin="0,4,0,0" Click="BrowseJpegDir_Click"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,8,0" Text="PNG保管先" VerticalAlignment="Center"/>
                    <TextBox x:Name="PngDirTextBox" Grid.Row="1" Grid.Column="1" Margin="0,4,8,0"/>
                    <Button x:Name="BrowsePngDirButton" Grid.Row="1" Grid.Column="2" Content="参照" Style="{StaticResource SecondaryButtonStyle}" Margin="0,4,0,0" Click="BrowsePngDir_Click"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8,8,0" Text="PNG扱い" VerticalAlignment="Center"/>
                    <ComboBox x:Name="WizardPngModeComboBox" Grid.Row="2" Grid.Column="1" Margin="0,4,8,0" SelectedIndex="0" SelectionChanged="WizardPngModeComboBox_SelectionChanged">
                        <ComboBoxItem Content="移動（Move）"/>
                        <ComboBoxItem Content="コピー（Copy）"/>
                        <ComboBoxItem Content="削除（Delete）"/>
                    </ComboBox>

                    <CheckBox x:Name="StartMonitoringCheckBox" Grid.Row="3" Grid.Column="1" Margin="0,14,0,0" Content="完了後に監視を開始する" IsChecked="True"/>
                    <CheckBox x:Name="LaunchOnWindowsStartupCheckBox" Grid.Row="4" Grid.Column="1" Margin="0,8,0,0" Content="Windows起動時にアプリ起動" IsChecked="True"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" Margin="0,8,0,0" Text="フォルダが存在しない場合は自動作成します。" Foreground="#5B6474"/>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="ValidationTextBlock" VerticalAlignment="Center" Foreground="#B42318"/>
            <Button x:Name="BackButton" Grid.Column="1" Content="戻る" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" Click="Back_Click" IsEnabled="False"/>
            <Button x:Name="NextButton" Grid.Column="2" Content="次へ" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" Click="Next_Click"/>
            <Button x:Name="FinishButton" Grid.Column="3" Content="完了" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" Click="Finish_Click" Visibility="Collapsed"/>
            <Button Grid.Column="4" Content="キャンセル" Style="{StaticResource SecondaryButtonStyle}" Click="Cancel_Click"/>
        </Grid>
    </Grid>
</Window>
