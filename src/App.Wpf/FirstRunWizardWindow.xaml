<Window x:Class="PhotoConverterApp.FirstRunWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="初回セットアップ"
        Height="560"
        Width="820"
        MinHeight="520"
        MinWidth="760"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock x:Name="StepHeaderTextBlock" Text="ステップ1/2 ゲームを選択" FontSize="24" FontWeight="SemiBold"/>
            <TextBlock x:Name="StepDescriptionTextBlock" Text="通常は VRChat のままで問題ありません。" Foreground="#5B6474" Margin="0,6,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource PanelBorderStyle}">
            <Grid>
                <Grid x:Name="Step1Panel">
                    <StackPanel Width="460" HorizontalAlignment="Left" VerticalAlignment="Top">
                        <TextBlock Text="ゲームプロファイル" Margin="0,0,0,8"/>
                        <ComboBox x:Name="PresetComboBox" SelectedIndex="0">
                            <ComboBoxItem Content="VRChat"/>
                        </ComboBox>
                        <TextBlock Text="この設定は後から設定画面で変更できます。" Foreground="#5B6474" Margin="0,10,0,0"/>
                    </StackPanel>
                </Grid>

                <Grid x:Name="Step2Panel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,8,8,0" Text="入力フォルダ" VerticalAlignment="Center"/>
                    <TextBox x:Name="SourceDirTextBox" Grid.Row="0" Grid.Column="1" Margin="0,4,8,0"/>
                    <Button Grid.Row="0" Grid.Column="2" Content="参照" Style="{StaticResource SecondaryButtonStyle}" Margin="0,4,0,0" Click="BrowseSourceDir_Click"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,8,0" Text="JPEG出力先" VerticalAlignment="Center"/>
                    <TextBox x:Name="JpegDirTextBox" Grid.Row="1" Grid.Column="1" Margin="0,4,8,0"/>
                    <Button Grid.Row="1" Grid.Column="2" Content="参照" Style="{StaticResource SecondaryButtonStyle}" Margin="0,4,0,0" Click="BrowseJpegDir_Click"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8,8,0" Text="PNG処理" VerticalAlignment="Center"/>
                    <ComboBox x:Name="WizardPngModeComboBox" Grid.Row="2" Grid.Column="1" Margin="0,4,8,0" SelectedIndex="0">
                        <ComboBoxItem Content="保持（Keep）"/>
                        <ComboBoxItem Content="削除（Delete）"/>
                    </ComboBox>

                    <CheckBox x:Name="StartMonitoringCheckBox" Grid.Row="3" Grid.Column="1" Margin="0,14,0,0" Content="起動直後に監視を開始する" IsChecked="True"/>
                    <CheckBox x:Name="LaunchOnWindowsStartupCheckBox" Grid.Row="4" Grid.Column="1" Margin="0,8,0,0" Content="Windows起動時にアプリを起動（最小化）" IsChecked="True"/>
                    <StackPanel Grid.Row="5" Grid.Column="1" Margin="0,8,0,0">
                        <CheckBox x:Name="ConvertExistingFilesCheckBox" Content="初回起動時に既存PNGも変換する" IsChecked="False"/>
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="#5B6474"
                                   TextWrapping="Wrap"
                                   Text="OFFの場合、既存PNGは『実施済み』として履歴に登録され、初回変換は行いません。"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="ValidationTextBlock" VerticalAlignment="Center" Foreground="#B42318"/>
            <Button x:Name="BackButton" Grid.Column="1" Content="戻る" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" Click="Back_Click" IsEnabled="False"/>
            <Button x:Name="NextButton" Grid.Column="2" Content="次へ" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" Click="Next_Click"/>
            <Button x:Name="FinishButton" Grid.Column="3" Content="完了" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" Click="Finish_Click" Visibility="Collapsed"/>
            <Button Grid.Column="4" Content="キャンセル" Style="{StaticResource SecondaryButtonStyle}" Click="Cancel_Click"/>
        </Grid>
    </Grid>
</Window>
